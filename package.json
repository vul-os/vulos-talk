{
  "name": "@vulos/talk-client",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite build && go run .",
    "dev:web": "concurrently -n \"vite,go\" -c \"cyan,green\" \"vite\" \"go run .\"",
    "build": "vite build && go build -o vulos-talk .",
    "build:frontend": "vite build",
    "build:go": "go build -o vulos-talk .",
    "start": "go run .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@vulos/relay-client": "file:../vulos-relay/client",
    "dompurify": "^3.4.5",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5",
    "vitest": "^4.1.7"
  }
}
